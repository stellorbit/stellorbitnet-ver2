{
  "name": "stellorbitnet",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "check": "astro check",
    "prebuild": "npm run prepare:posts",
    "precheck": "npm run prepare:posts",
    "preview": "astro preview",
    "astro": "astro",
    "new:post": "node ./scripts/new-astro-post.mjs",
    "sync:post-headings": "node ./scripts/sync-astro-post-headings.mjs",
    "check:images": "node ./scripts/check-image-references.mjs",
    "prepare:posts": "npm run sync:post-headings && npm run check:images",
    "docs:pdf": "node ./scripts/build-post-workflow-pdf.mjs",
    "deploy": "npm run build && node ./scripts/deploy-pages.mjs",
    "deploy:skip-build": "node ./scripts/deploy-pages.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.1.8",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-toc": "^9.0.0",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "typescript": "^5.9.3",
    "wrangler": "^4.83.0"
  }
}
