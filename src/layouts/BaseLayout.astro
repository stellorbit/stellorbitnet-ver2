---
// src/layouts/BaseLayout.astro
const { title, description } = Astro.props;
---

<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <header>
      <h1>stellorbit</h1>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>© stellorbit</p>
    </footer>
  </body>
</html>