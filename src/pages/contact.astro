---
import BaseLayout from '../layouts/BaseLayout.astro';

const googleFormEmbedUrl =
	'https://docs.google.com/forms/d/e/1FAIpQLSe2cV63WANUPCO8m_dtu9fVYoAkt53fjn5vI-6NxfA6r_-Qwg/viewform?embedded=true';
---

<BaseLayout title="Contact" description="軌道を描こう。【改】のお問い合わせフォーム。">
	<div class="shell">
		<section class="content-panel">
			<div class="page-heading">
				<p class="eyebrow">Contact</p>
				<h1>お問い合わせ</h1>
				<p class="page-lead">
					以下のフォームよりお問い合わせください。通常2〜3営業日以内にご返信いたします。
				</p>
			</div>

			<div class="contact-frame">
				<iframe
					src={googleFormEmbedUrl}
					title="お問い合わせフォーム"
					width="100%"
					height="800"
					frameborder="0"
					marginheight="0"
					marginwidth="0"
				>
					読み込んでいます…
				</iframe>
			</div>
		</section>
	</div>
</BaseLayout>

<style>
	.contact-frame {
		border: 1px solid var(--line);
		border-radius: 24px;
		overflow: hidden;
		background: rgba(255, 255, 255, 0.75);
	}

	.contact-frame iframe {
		display: block;
		min-height: 800px;
		background: transparent;
	}
</style>
