---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Home" description={SITE_DESCRIPTION}>
	<div class="shell">
		<section class="hero-panel hero-panel--compact">
			<div class="hero-copy hero-copy--compact">
				<p class="eyebrow">Notes and Reviews</p>
				<h1>PC、制作環境、Webまわりの記録。</h1>
				<p>
					実体験ベースのレビュー、検証、長文メモをまとめています。トップページからそのまま記事を追える構成です。
				</p>
				<div class="hero-actions">
					<a class="button-link--ghost" href="/about/">サイトについて</a>
				</div>
			</div>
		</section>

		<section class="content-panel" style="margin-top: 1.5rem;">
			<div class="page-heading">
				<p class="eyebrow">Articles</p>
				<h1>記事一覧</h1>
				<p class="page-lead">
					公開済みの記事を新しい順に表示しています。
				</p>
			</div>
			<div class="post-list">
				{posts.map((post) => (
					<a class="post-card" href={`/blog/${post.id}/`}>
						<p class="card-meta">{post.data.pubDate.toLocaleDateString('ja-JP')}</p>
						<h2>{post.data.title}</h2>
						<p>{post.data.description}</p>
						{post.data.tags.length > 0 && (
							<ul class="tag-list">
								{post.data.tags.slice(0, 3).map((tag) => <li>{tag}</li>)}
							</ul>
						)}
					</a>
				))}
			</div>
		</section>
	</div>
</BaseLayout>
