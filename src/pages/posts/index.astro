---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getListedPosts } from '../../lib/posts';

const posts = await getListedPosts();
---

<BaseLayout title="Posts" description="記事アーカイブ一覧。PC、制作環境、Webに関する長文記事を掲載しています。">
	<div class="shell">
		<section class="content-panel">
			<div class="page-heading">
				<p class="eyebrow">Posts Archive</p>
				<h1>記事一覧</h1>
				<p class="page-lead">
					公開済みの記事を新しい順にまとめています。
				</p>
			</div>
			<div class="post-list">
				{posts.map((post) => (
					<a class="post-card" href={post.link}>
						<p class="card-meta">{post.pubDate.toLocaleDateString('ja-JP')}</p>
						<h2>{post.title}</h2>
						<p>{post.description}</p>
						{post.tags.length > 0 && (
							<ul class="tag-list">
								{post.tags.map((tag) => <li>{tag}</li>)}
							</ul>
						)}
					</a>
				))}
			</div>
		</section>
	</div>
</BaseLayout>
